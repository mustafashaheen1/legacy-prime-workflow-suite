{
  "crons": [
    {
      "path": "/api/check-schedule-reminders",
      "schedule": "0 8 * * *"
    }
  ],
  "buildCommand": "bunx expo export -p web",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "functions": {
    "api/ai-estimate.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/speech-to-text.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/ai-assistant.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/create-estimate.ts": {
      "maxDuration": 10,
      "memory": 512
    },
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/update-project.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/add-payment.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/check-task-reminders.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/voice-webhook.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/twilio-webhook.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/team/send-message.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/**/*.ts": {
      "maxDuration": 10,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/create-estimate", "destination": "/api/create-estimate" },
    { "source": "/api/stripe-payment", "destination": "/api/stripe-payment" },
    { "source": "/api/activate-subscription", "destination": "/api/activate-subscription" },
    { "source": "/trpc/(.*)", "destination": "/api" },
{ "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}

